# This project was developed with assistance from AI tools.

# Stage 1: Build static assets
FROM registry.access.redhat.com/ubi9/nodejs-20:latest AS builder

WORKDIR /opt/app-root/src

# Copy root package files for workspace setup
COPY --chown=1001:0 package.json pnpm-lock.yaml pnpm-workspace.yaml ./

# Copy workspace config packages (UI depends on them)
COPY --chown=1001:0 packages/configs/ packages/configs/
COPY --chown=1001:0 packages/ui/package.json packages/ui/package.json

# Install pnpm and dependencies
RUN npm install -g pnpm && pnpm install --frozen-lockfile 2>/dev/null || pnpm install

# Copy UI source
COPY --chown=1001:0 packages/ui/ packages/ui/

# Build the UI application (vite only, skip storybook)
RUN cd packages/ui && pnpm build:vite

# Stage 2: Serve with Nginx
FROM registry.access.redhat.com/ubi9/nginx-124:latest

# Copy built assets
COPY --from=builder /opt/app-root/src/packages/ui/dist /opt/app-root/src

# Nginx location configs (injected into the default server block)
RUN echo 'client_max_body_size 50m;' > /opt/app-root/etc/nginx.default.d/upload-limit.conf && \
    echo 'location /api/ { \
    proxy_pass http://model-evaluation-api:8000/; \
    proxy_set_header Host $host; \
    proxy_set_header X-Real-IP $remote_addr; \
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for; \
    proxy_set_header X-Forwarded-Proto $scheme; \
    proxy_read_timeout 600s; \
    proxy_send_timeout 600s; \
}' > /opt/app-root/etc/nginx.default.d/api-proxy.conf && \
    echo 'location / { \
    try_files $uri $uri/ /index.html; \
} \
location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ { \
    expires 1y; \
    add_header Cache-Control "public, immutable"; \
}' > /opt/app-root/etc/nginx.default.d/spa-routing.conf

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD curl -sf http://localhost:8080/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
