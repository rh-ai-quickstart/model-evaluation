# This project was developed with assistance from AI tools.

# Stage 1: Build dependencies
FROM registry.access.redhat.com/ubi9/python-312:latest AS builder

WORKDIR /app

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy DB package (API depends on it)
COPY packages/db/ packages/db/

# Copy API package files
COPY packages/api/pyproject.toml packages/api/pyproject.toml
COPY packages/api/src/ packages/api/src/

# Install dependencies (db package first, then API)
WORKDIR /app/packages/db
RUN uv pip install --system . || pip install .
WORKDIR /app/packages/api
RUN uv pip install --system . || pip install .

# Stage 2: Runtime
FROM registry.access.redhat.com/ubi9/python-312:latest

WORKDIR /app

# Copy installed packages from builder
COPY --from=builder /opt/app-root/lib/python3.12/site-packages /opt/app-root/lib/python3.12/site-packages
COPY --from=builder /opt/app-root/bin /opt/app-root/bin

# Copy application source
COPY packages/api/src/ packages/api/src/
COPY packages/api/pyproject.toml packages/api/pyproject.toml
COPY packages/db/src/ packages/db/src/
COPY packages/db/pyproject.toml packages/db/pyproject.toml

# Copy Alembic files for migrations
COPY packages/db/alembic/ packages/db/alembic/
COPY packages/db/alembic.ini packages/db/alembic.ini

ENV PYTHONPATH="/app/packages/db/src:/app/packages/api/src"

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health/live')" || exit 1

CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8000"]
